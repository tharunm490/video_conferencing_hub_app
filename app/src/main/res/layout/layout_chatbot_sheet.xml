<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1F2937"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/chatbot_title"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/chatbot_subtitle"
        android:textColor="#9CA3AF"
        android:textSize="12sp"
        android:layout_marginBottom="12dp"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvChatbot"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <ProgressBar
        android:id="@+id/pbChatbot"
        style="?android:attr/progressBarStyleSmall"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone"
        android:layout_marginVertical="8dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="8dp">

        <EditText
            android:id="@+id/etChatbotInput"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="@string/chatbot_hint"
            android:inputType="textLongMessage"
            android:autofillHints="none"
            android:textColor="#FFFFFF"
            android:textColorHint="#6B7280"
            android:background="@drawable/bg_input_dark"
            android:padding="12dp"
            android:textSize="14sp"/>

        <ImageButton
            android:id="@+id/btnChatbotSend"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_circle_blue"
            android:src="@drawable/ic_send"
            android:padding="12dp"
            android:contentDescription="Send to AI"
            app:tint="@android:color/white"
            xmlns:app="http://schemas.android.com/apk/res-auto"/>
    </LinearLayout>
</LinearLayout>
