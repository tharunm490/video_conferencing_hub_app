<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#111827">

    <TextView
        android:id="@+id/textMeetingTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginTop="20dp"
        android:layout_marginEnd="20dp"
        android:text="Meeting"
        android:textColor="@android:color/white"
        android:textSize="22sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/textMeetingSubtitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:visibility="gone"
        android:text="Joined as user"
        android:textColor="#D1D5DB"
        android:textSize="14sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="@+id/textMeetingTitle"
        app:layout_constraintTop_toBottomOf="@+id/textMeetingTitle" />

    <HorizontalScrollView
        android:id="@+id/horizontalScrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:scrollbars="none"
        app:layout_constraintBottom_toTopOf="@+id/layoutControls"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/textMeetingTitle">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="horizontal">

            <androidx.camera.view.PreviewView
                android:id="@+id/previewView"
                android:layout_width="411dp"
                android:layout_height="match_parent" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerParticipants"
                android:layout_width="411dp"
                android:layout_height="match_parent"
                android:background="#111827"
                android:padding="16dp" />

        </LinearLayout>
    </HorizontalScrollView>

    <FrameLayout
        android:id="@+id/reactionContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@+id/layoutControls"
        app:layout_constraintTop_toTopOf="parent" />

    <LinearLayout
        android:id="@+id/layoutReactions"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:background="@drawable/bg_circle_dark"
        android:orientation="horizontal"
        android:padding="4dp"
        app:layout_constraintBottom_toTopOf="@+id/layoutControls"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <TextView
            android:id="@+id/btnReactThumb"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:gravity="center"
            android:text="👍"
            android:textSize="20sp" />

        <TextView
            android:id="@+id/btnReactHeart"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:gravity="center"
            android:text="❤️"
            android:textSize="20sp" />

        <TextView
            android:id="@+id/btnReactParty"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:gravity="center"
            android:text="🎉"
            android:textSize="20sp" />

        <TextView
            android:id="@+id/btnReactClap"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:gravity="center"
            android:text="👏"
            android:textSize="20sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layoutControls"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:background="#1F2937"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/buttonMic"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_margin="8dp"
                android:background="@drawable/bg_circle_dark"
                android:contentDescription="Mic"
                android:padding="14dp"
                android:src="@drawable/ic_mic" />

            <ImageButton
                android:id="@+id/buttonCamera"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_margin="8dp"
                android:background="@drawable/bg_circle_dark"
                android:contentDescription="Camera"
                android:padding="14dp"
                android:src="@drawable/ic_videocam" />

            <ImageButton
                android:id="@+id/buttonEndCall"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_margin="8dp"
                android:background="@drawable/bg_circle_red"
                android:contentDescription="End Call"
                android:padding="14dp"
                android:src="@drawable/ic_call_end" />

            <ImageButton
                android:id="@+id/buttonSwitchCamera"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_margin="8dp"
                android:background="@drawable/bg_circle_dark"
                android:contentDescription="Switch Camera"
                android:padding="14dp"
                android:src="@drawable/ic_videocam" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/buttonChat"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_margin="8dp"
                android:background="@drawable/bg_circle_dark"
                android:contentDescription="Chat"
                android:padding="14dp"
                android:src="@drawable/ic_chat" />

            <ImageButton
                android:id="@+id/buttonParticipants"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_margin="8dp"
                android:background="@drawable/bg_circle_dark"
                android:contentDescription="Participants"
                android:padding="14dp"
                android:src="@drawable/ic_people" />

            <ImageButton
                android:id="@+id/buttonShare"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_margin="8dp"
                android:background="@drawable/bg_circle_dark"
                android:contentDescription="Share"
                android:padding="14dp"
                android:src="@drawable/ic_share" />

            <ImageButton
                android:id="@+id/buttonAiSummary"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_margin="8dp"
                android:background="@drawable/bg_circle_dark"
                android:contentDescription="AI Summary"
                android:padding="14dp"
                android:src="@drawable/ic_ai_summary"
                app:tint="@android:color/white" />

        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
