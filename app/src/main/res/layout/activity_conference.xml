<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#111827">

    <TextView
        android:id="@+id/textMeetingTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginTop="50dp"
        android:layout_marginEnd="20dp"
        android:text="@string/meeting"
        android:textColor="@android:color/white"
        android:textSize="22sp"
        android:textStyle="bold"
        android:elevation="10dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <org.webrtc.SurfaceViewRenderer
        android:id="@+id/remote_view"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@+id/layoutControls"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/textRemoteUserName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="8dp"
        android:background="#80000000"
        android:paddingHorizontal="8dp"
        android:paddingVertical="4dp"
        android:text="@string/waiting_for_participant"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:elevation="10dp"
        app:layout_constraintBottom_toBottomOf="@+id/remote_view"
        app:layout_constraintStart_toStartOf="@+id/remote_view" />

    <org.webrtc.SurfaceViewRenderer
        android:id="@+id/local_view"
        android:layout_width="120dp"
        android:layout_height="180dp"
        android:layout_margin="16dp"
        android:elevation="11dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/textMeetingTitle" />

    <TextView
        android:id="@+id/textLocalUserName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="4dp"
        android:background="#80000000"
        android:paddingHorizontal="4dp"
        android:text="@string/you"
        android:textColor="@android:color/white"
        android:textSize="12sp"
        android:elevation="12dp"
        app:layout_constraintBottom_toBottomOf="@+id/local_view"
        app:layout_constraintEnd_toEndOf="@+id/local_view"
        app:layout_constraintStart_toStartOf="@+id/local_view" />

    <FrameLayout
        android:id="@+id/reactionContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@+id/layoutControls"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/textSpeechStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:background="#80000000"
        android:paddingHorizontal="8dp"
        android:paddingVertical="2dp"
        android:text="Listening..."
        android:textColor="#4ADE80"
        android:textSize="12sp"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@+id/layoutReactions"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <LinearLayout
        android:id="@+id/layoutReactions"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:background="@drawable/bg_circle_dark"
        android:orientation="horizontal"
        android:padding="4dp"
        app:layout_constraintBottom_toTopOf="@+id/layoutControls"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <TextView
            android:id="@+id/btnReactThumb"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:gravity="center"
            android:text="👍"
            android:textSize="20sp" />

        <TextView
            android:id="@+id/btnReactHeart"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:gravity="center"
            android:text="❤️"
            android:textSize="20sp" />

        <TextView
            android:id="@+id/btnReactParty"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:gravity="center"
            android:text="🎉"
            android:textSize="20sp" />

        <TextView
            android:id="@+id/btnReactClap"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:gravity="center"
            android:text="👏"
            android:textSize="20sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layoutControls"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:background="#1F2937"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/buttonMic"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_margin="8dp"
                android:background="@drawable/bg_circle_dark"
                android:contentDescription="@string/mic_desc"
                android:padding="14dp"
                android:src="@drawable/ic_mic" />

            <ImageButton
                android:id="@+id/buttonCamera"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_margin="8dp"
                android:background="@drawable/bg_circle_dark"
                android:contentDescription="@string/camera_desc"
                android:padding="14dp"
                android:src="@drawable/ic_videocam" />

            <ImageButton
                android:id="@+id/buttonEndCall"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_margin="8dp"
                android:background="@drawable/bg_circle_red"
                android:contentDescription="@string/end_call_desc"
                android:padding="14dp"
                android:src="@drawable/ic_call_end" />

            <ImageButton
                android:id="@+id/buttonSwitchCamera"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_margin="8dp"
                android:background="@drawable/bg_circle_dark"
                android:contentDescription="@string/switch_camera_desc"
                android:padding="14dp"
                android:src="@drawable/ic_videocam" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/buttonChat"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_margin="8dp"
                android:background="@drawable/bg_circle_dark"
                android:contentDescription="@string/chat_desc"
                android:padding="14dp"
                android:src="@drawable/ic_chat" />

            <ImageButton
                android:id="@+id/buttonParticipants"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_margin="8dp"
                android:background="@drawable/bg_circle_dark"
                android:contentDescription="@string/participants_desc"
                android:padding="14dp"
                android:src="@drawable/ic_people" />

            <ImageButton
                android:id="@+id/buttonShare"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_margin="8dp"
                android:background="@drawable/bg_circle_dark"
                android:contentDescription="@string/share_desc"
                android:padding="14dp"
                android:src="@drawable/ic_share" />

            <ImageButton
                android:id="@+id/buttonAiSummary"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_margin="8dp"
                android:background="@drawable/bg_circle_dark"
                android:contentDescription="@string/ai_summary_desc"
                android:padding="14dp"
                android:src="@drawable/ic_ai_summary"
                app:tint="@android:color/white" />

        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
